# Copy this file to .env.local and fill in as needed.

# Catalog source: "aic" (default, no key needed) or "harvard" (requires key below)
VITE_CATALOG_SOURCE=aic

# Harvard Art Museums API key. Free. Request at:
# https://harvardartmuseums.org/collections/api
# Only required if VITE_CATALOG_SOURCE=harvard
VITE_HARVARD_API_KEY=
